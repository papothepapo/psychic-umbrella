{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Inkline",
  "version": "0.1.0",
  "identifier": "app.inkline.studio",
  "build": {
    "beforeBuildCommand": "pnpm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "Inkline",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600
      }
    ]
  },
  "bundle": {
    "active": true,
    "publisher": "Inkline",
    "copyright": "Copyright (c) 2026 Inkline",
    "category": "Productivity",
    "shortDescription": "A snapshot-first writing studio.",
    "longDescription": "Inkline is a writing app for drafting, snapshotting, comparing, and exporting long-form work.",
    "icon": [
      "icons/icon-32.png",
      "icons/icon-128.png",
      "icons/icon-256.png",
      "icons/icon.ico"
    ]
  }
}
